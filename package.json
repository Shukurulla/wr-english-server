{
  "name": "rwplatform-backend",
  "version": "0.1.0",
  "description": "Reading & Writing platform backend (Express + MongoDB)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src",
    "seed:tasks": "node src/seed/seed-tasks.js",
    "seed:final-test": "node src/seed/seed-final-test.js",
    "seed:users": "node src/seed/seed-users.js",
    "fix:writing-grades": "node src/seed/fix-writing-grades.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.4",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.6",
    "eslint": "^9.16.0",
    "mongodb-memory-server": "^10.1.2",
    "nock": "^13.5.6",
    "supertest": "^7.0.0",
    "vitest": "^2.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
